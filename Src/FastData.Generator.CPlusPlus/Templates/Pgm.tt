        size_t hi = static_cast<size_t>(pos) + <#= (Data.Epsilon + 2).ToStringInvariant() #>;
        if (hi > <#= Data.KeyCount.ToStringInvariant() #>) hi = <#= Data.KeyCount.ToStringInvariant() #>;

        while (lo < hi) {
            const size_t mid = lo + ((hi - lo) >> 1);
            const <#= KeyTypeName #> mid_key = keys[mid];
            if (mid_key == <#= LookupKeyName #>)
                return true;
            if (mid_key < <#= LookupKeyName #>)
                lo = mid + 1;
            else
                hi = mid;
