#>
        const int32_t pos = get_segment_pos(<#= LookupKeyName #>);

        size_t lo = pos >= <#= Data.Epsilon.ToStringInvariant() #> ? static_cast<size_t>(pos - <#= Data.Epsilon.ToStringInvariant() #>) : 0;
        size_t hi = static_cast<size_t>(pos) + <#= (Data.Epsilon + 2).ToStringInvariant() #>;
