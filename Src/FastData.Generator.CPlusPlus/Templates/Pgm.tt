        const double product = static_cast<double>(<#= formatSlope(seg0Slope) #>) * <#= string.Format(cppDiffExpr, segKeyConst) #>;
        int32_t pos = product <= 0.0 ? 0 : (product >= static_cast<double>(<#= seg0MaxProduct.ToStringInvariant() #>) ? <#= seg0MaxProduct.ToStringInvariant() #> : static_cast<int32_t>(product));
