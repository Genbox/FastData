<#
            if (seg0Slope == 0)
            {
#>
<#= needsUnchecked ? "    " : "" #>        int pos = <#= seg0Intercept.ToStringInvariant() #>;
<#
            }
            else
            {
#>
<#= needsUnchecked ? "    " : "" #>        double diff = <#= string.Format(csharpDiffExpr, segKeyConst) #>;
<#= needsUnchecked ? "    " : "" #>        int pos = (int)(long)(<#= formatSlope(seg0Slope) #> * diff);
<#= needsUnchecked ? "    " : "" #>        if (pos < 0) pos = 0;
<#              if (seg0Intercept != 0) { #>
<#= needsUnchecked ? "    " : "" #>        pos += <#= seg0Intercept.ToStringInvariant() #>;
<#              } #>
<#= needsUnchecked ? "    " : "" #>        if (pos > <#= Data.KeyCount.ToStringInvariant() #>) pos = <#= Data.KeyCount.ToStringInvariant() #>;
<#
            }
#>

<#= needsUnchecked ? "    " : "" #>        int lo = pos - <#= Data.Epsilon.ToStringInvariant() #>;
<#= needsUnchecked ? "    " : "" #>        if (lo < 0) lo = 0;
<#= needsUnchecked ? "    " : "" #>        int hi = pos + <#= (Data.Epsilon + 2).ToStringInvariant() #>;
<#= needsUnchecked ? "    " : "" #>        if (hi > <#= Data.KeyCount.ToStringInvariant() #>) hi = <#= Data.KeyCount.ToStringInvariant() #>;

<#= needsUnchecked ? "    " : "" #>        while (lo < hi)
<#= needsUnchecked ? "    " : "" #>        {
<#= needsUnchecked ? "    " : "" #>            int i = lo + ((hi - lo) >> 1);
<#= needsUnchecked ? "    " : "" #>            if (_keys[i] == <#= LookupKeyName #>)
<#= needsUnchecked ? "    " : "" #>            {
<#= needsUnchecked ? "    " : "" #>                value = _values[i];
<#= needsUnchecked ? "    " : "" #>                return true;
<#= needsUnchecked ? "    " : "" #>            }
<#= needsUnchecked ? "    " : "" #>            if (_keys[i] < <#= LookupKeyName #>)
<#= needsUnchecked ? "    " : "" #>                lo = i + 1;
<#= needsUnchecked ? "    " : "" #>            else
<#= needsUnchecked ? "    " : "" #>                hi = i;
<#= needsUnchecked ? "    " : "" #>        }

<#= needsUnchecked ? "    " : "" #>        value = default;
<#= needsUnchecked ? "    " : "" #>        return false;
<#          if (needsUnchecked) { #>
        }
<#          } #>
<#
        }
        else
        {
#>
        int pos = GetSegmentPos(<#= LookupKeyName #>);

        int lo = pos - <#= Data.Epsilon.ToStringInvariant() #>;
        if (lo < 0) lo = 0;
        int hi = pos + <#= (Data.Epsilon + 2).ToStringInvariant() #>;
        if (hi > <#= Data.KeyCount.ToStringInvariant() #>) hi = <#= Data.KeyCount.ToStringInvariant() #>;

        while (lo < hi)
        {
            int i = lo + ((hi - lo) >> 1);
            if (_keys[i] == <#= LookupKeyName #>)
            {
                value = _values[i];
                return true;
            }
            if (_keys[i] < <#= LookupKeyName #>)
                lo = i + 1;
